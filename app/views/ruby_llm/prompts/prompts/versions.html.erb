<h2 class="mono"><%= @prompt.slug %></h2>
<p class="meta">Version history</p>

<table>
  <thead>
    <tr>
      <th>Version</th>
      <th>Status</th>
      <th>Created</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @versions.each_with_index do |version, i| %>
      <tr>
        <td>v<%= version.version %></td>
        <td>
          <% if version.active? %>
            <span class="version-badge version-active">active</span>
          <% else %>
            <span class="version-badge">inactive</span>
          <% end %>
        </td>
        <td class="meta"><%= version.created_at.strftime("%Y-%m-%d %H:%M") %></td>
        <td>
          <% unless version.active? %>
            <%= button_to "Restore", rollback_prompt_path(version.slug), class: "btn btn-danger", form: { style: "display:inline" } %>
          <% end %>
        </td>
      </tr>
      <% previous = @versions[i + 1] %>
      <% if previous %>
        <% body_changed = version.body != previous.body %>
        <% system_changed = version.system_message != previous.system_message %>
        <% if body_changed || system_changed %>
          <tr>
            <td colspan="4" class="diff-cell">
              <% if system_changed %>
                <div class="diff-label">System message changed:</div>
                <div class="diff-block">
                  <div class="diff-old"><%= previous.system_message %></div>
                  <div class="diff-arrow">&darr;</div>
                  <div class="diff-new"><%= version.system_message %></div>
                </div>
              <% end %>
              <% if body_changed %>
                <div class="diff-label">Body changed:</div>
                <div class="diff-block">
                  <div class="diff-old"><%= previous.body %></div>
                  <div class="diff-arrow">&darr;</div>
                  <div class="diff-new"><%= version.body %></div>
                </div>
              <% end %>
            </td>
          </tr>
        <% end %>
      <% end %>
    <% end %>
  </tbody>
</table>

<div class="actions">
  <%= link_to "Back", prompt_path(@prompt.slug), class: "btn" %>
</div>
